# Copier ce fichier en .env et adapter les valeurs

DEBUG=True
SECRET_KEY=change-moi-en-production
ALLOWED_HOSTS=127.0.0.1,localhost

# Si DATABASE_URL n'est pas défini, le projet utilise SQLite par défaut (pratique pour lancer vite)
# Exemple PostgreSQL :
# DATABASE_URL=postgres://user:password@localhost:5432/explore_ci

# --- Déploiement (Semaine 2) ---
# Render/Railway/Heroku fournissent DATABASE_URL automatiquement en général.
# Render seul : injecte aussi RENDER_EXTERNAL_HOSTNAME (ajouté à ALLOWED_HOSTS automatiquement).
# RENDER_EXTERNAL_HOSTNAME=explore-ci-backend.onrender.com

# Domaines autorisés à appeler l'API en CORS (utile pour Flutter Web / tests navigateur).
# En dev (DEBUG=True), tous les domaines sont déjà autorisés automatiquement.
# CORS_ALLOWED_ORIGINS=https://mon-domaine.com,https://autre-domaine.com
